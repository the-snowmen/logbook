{
  "name": "logbook",
  "displayName": "logbook",
  "description": "An always-on, gitignored dev journal for any project — decisions (ADRs), phases, session summaries, troubleshooting runbooks, and session-to-session handoffs. Sessions auto-start with a read-back digest, work is recorded as it happens, and a compaction-safe checkpoint protects against context loss. Survives context resets.",
  "version": "0.6.0",
  "author": {
    "name": "the-snowmen"
  },
  "homepage": "https://github.com/the-snowmen/logbook",
  "repository": "https://github.com/the-snowmen/logbook",
  "license": "MIT",
  "keywords": [
    "journal",
    "dev-journal",
    "adr",
    "decision-records",
    "handoff",
    "memory",
    "notes",
    "runbook",
    "hooks",
    "always-on"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/logbook-activate.js\"",
            "timeout": 5,
            "statusMessage": "Reading logbook..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/logbook-tracker.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/logbook-precompact.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/logbook-stop.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/logbook-session-end.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
